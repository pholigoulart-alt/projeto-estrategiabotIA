# SEÇÃO 2 — FEATURE ENGINEERING E LABEL
# (Chollet 4.1.2: "Preparing the data")
# ══════════════════════════════════════════════════════════════════════════════
# ⚠️  REGRA ANTI-DATA-LEAKAGE: a coluna vela_dir é o resultado REAL da vela.
#     Ela é o TARGET (y), nunca pode ser uma feature (X).
#     A coluna decisao também é excluída — ela é a previsão do bot, não o resultado.
#     As features são apenas o que o bot SABIA aos T-10s, ANTES da vela fechar.

print(f"\n[2] FEATURE ENGINEERING")

def preparar_features(df):
    """
    Extrai X (features) e y (labels) do radar_velas.csv.

    ⚠️  ANTI-LEAKAGE:
      - Exclui: vela_dir, var_pct, close (resultado da vela — futuro)
      - Mantém: tudo que o bot calcula ANTES da vela fechar (T-10s)

    Features usadas (o que o radar já calcula hoje):
      bbw        : Bollinger Band Width — expansão/contração do mercado
      bbw_perc   : percentil do BBW — contexto histórico
      squeeze    : bool → squeeze ativo?
      delta_buy  : fração de volume compradora agressiva
      delta_sell : fração de volume vendedora (= 1 - delta_buy, redundante mas útil)
      body_pct   : (close-open)/open × 100 — EXCLUÍDO (usa close → futuro)
      high_pct   : (high-open)/open × 100 — EXCLUÍDO (usa high → futuro parcial)

    Features adicionais derivadas só do passado (T-10s são conhecidos):
      delta_ratio : delta_buy / (delta_sell + 1e-8) — razão de pressão
      bbw_norm    : bbw × bbw_perc / 100 — BBW ponderado pelo contexto

    Label y:
      1 = UP   (vela fechou acima da abertura → token UP vence)
      0 = DOWN (vela fechou abaixo da abertura → token DOWN vence)
      Linhas FLAT excluídas (mercado lateral — sem sinal binário claro)
    """
    df = df.copy()

    # Remove linhas sem direção clara (FLAT)
    df = df[df["vela_dir"].isin(["UP", "DOWN"])].copy()

    # Features seguras (todas conhecidas no T-10s, ANTES da vela fechar)
    df["delta_ratio"] = df["delta_buy"] / (df["delta_sell"] + 1e-8)
    df["bbw_norm"]    = df["bbw"] * df["bbw_perc"] / 100.0

    FEATURES = ["bbw", "bbw_perc", "squeeze", "delta_buy", "delta_sell",
                "delta_ratio", "bbw_norm"]

    X = df[FEATURES].astype(np.float32).values
    y = (df["vela_dir"] == "UP").astype(np.float32).values

    return X, y, FEATURES, df.index

X, y, FEATURE_NAMES, idx_validos = preparar_features(df_raw)

n_up   = int(y.sum())
n_down = int((1 - y).sum())
print(f"    Amostras após remover FLAT: {len(X):,}")
print(f"    UP  : {n_up:,}  ({n_up/len(y)*100:.1f}%)")
print(f"    DOWN: {n_down:,}  ({n_down/len(y)*100:.1f}%)")
print(f"    Features ({len(FEATURE_NAMES)}): {FEATURE_NAMES}")

# Aviso de desbalanceamento (Chollet 5: cuide das classes)
balance_ratio = min(n_up, n_down) / max(n_up, n_down)
if balance_ratio < 0.70:
    print(f"    ⚠️  Classes desbalanceadas (ratio={balance_ratio:.2f}) — "
          f"use class_weight no treino.")
else:
