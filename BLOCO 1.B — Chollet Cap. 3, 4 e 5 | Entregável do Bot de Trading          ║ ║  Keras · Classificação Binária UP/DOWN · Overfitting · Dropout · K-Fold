# SEÇÃO 3 — SPLIT TEMPORAL  (Chollet 5.2, 10.2)
# ══════════════════════════════════════════════════════════════════════════════
# Chollet 10.2: "it's important to use validation and test data that is MORE
# RECENT than the training data — you're trying to predict the future given
# the past, not the reverse."
#
# ⚠️  NUNCA use np.random.shuffle() em dados financeiros!
#     Baralhar misturaria o futuro com o passado → data leakage grave.
#     O split é sempre CRONOLÓGICO: train < val < test.

print(f"\n[3] SPLIT TEMPORAL (cronológico — sem shuffle)")

n   = len(X)
i70 = int(0.70 * n)
i85 = int(0.85 * n)

X_train, y_train = X[:i70],      y[:i70]
X_val,   y_val   = X[i70:i85],   y[i70:i85]
X_test,  y_test  = X[i85:],      y[i85:]

print(f"    Train   : {len(X_train):>5} amostras  (0% → 70%)   UP={y_train.mean()*100:.0f}%")
print(f"    Val     : {len(X_val):>5} amostras  (70% → 85%)  UP={y_val.mean()*100:.0f}%")
print(f"    Test    : {len(X_test):>5} amostras  (85% → 100%) UP={y_test.mean()*100:.0f}%")
print(f"    ✅ Dados de teste são os MAIS RECENTES — simula produção corretamente.")


# ══════════════════════════════════════════════════════════════════════════════
# SEÇÃO 4 — NORMALIZAÇÃO  (Chollet 3.6, 10.2.1)
# ══════════════════════════════════════════════════════════════════════════════
# Calculada APENAS no treino. Aplicada igual em val/test e em produção.
# Chollet: "compute mean and std on the training data only"

print(f"\n[4] NORMALIZAÇÃO (calculada no treino, aplicada em val/test)")

mean_tr = X_train.mean(axis=0)
std_tr  = X_train.std(axis=0) + 1e-8   # evita divisão por zero

X_train_n = (X_train - mean_tr) / std_tr
X_val_n   = (X_val   - mean_tr) / std_tr
X_test_n  = (X_test  - mean_tr) / std_tr

print(f"    Feature stats (treino normalizado):")
print(f"    {'Feature':<14} {'Média':>8} {'Std':>8}")
print(f"    {'-'*32}")
for nome, m, s in zip(FEATURE_NAMES, mean_tr, std_tr):
    print(f"    {nome:<14} {m:>8.4f} {s:>8.4f}")

# Salva parâmetros de normalização para uso em produção
norm_params = {"mean": mean_tr.tolist(), "std": std_tr.tolist(),
               "features": FEATURE_NAMES}
import json
with open("/mnt/user-data/outputs/norm_params_bloco1b.json", "w") as f:
    json.dump(norm_params, f, indent=2)
print(f"\n    ✅ Parâmetros salvos em norm_params_bloco1b.json")
print(f"       (CARREGAR no bot na inferência — não recalcular!)")


# ══════════════════════════════════════════════════════════════════════════════
# SEÇÃO 5 — BASELINE BURRO  (Chollet 10.2: "always start with a naive baseline")
# ══════════════════════════════════════════════════════════════════════════════
# Antes de qualquer modelo, precisamos saber o que é "ganhar por acaso".
# Se o baseline já tem 60% de acurácia, nosso modelo precisa superar isso.

print(f"\n[5] BASELINE BURRO (Chollet 10.2 — sempre compare com o mais simples)")

# Baseline 1: chuta sempre UP (classe majoritária)
baseline_sempre_up = y_test.mean()
# Baseline 2: regra atual do bot (squeeze + delta >= 0.70 → UP)
idx_sniper = (X_test[:, 2] == 1) & (X_test[:, 3] >= 0.70)  # squeeze & delta_buy
y_pred_regras = np.where(idx_sniper, 1.0, 0.0)
# Para amostras sem squeeze, usa delta_buy > 0.5 como desempate
sem_squeeze = ~idx_sniper
y_pred_regras[sem_squeeze] = (X_test[sem_squeeze, 3] > 0.5).astype(float)
acc_regras = (y_pred_regras == y_test).mean()

print(f"    Baseline 1 — sempre UP          : {baseline_sempre_up*100:.1f}%")
print(f"    Baseline 2 — regras if/else bot : {acc_regras*100:.1f}%")
print(f"    → Nosso modelo DL precisa superar {max(baseline_sempre_up, acc_regras)*100:.1f}%")
print(f"       para justificar a complexidade.")


# ══════════════════════════════════════════════════════════════════════════════
# SEÇÃO 6 — ARQUITETURA DO MODELO  (Chollet 4.1.3, 5.4.4)
# ══════════════════════════════════════════════════════════════════════════════
# Chollet 4.1.3: "In a binary classification problem, your model should end
# with a Dense layer with one unit and a sigmoid activation."
#
# Chollet 5.4.4 (Dropout): "one of the most effective and most commonly used
# regularization techniques for neural networks."
# "applied to a layer, consists of randomly dropping out a number of output
# features during training" — taxa típica: 0.2 a 0.5.

print(f"\n[6] MODELO — Dense + Dropout (Chollet 4.1.3 + 5.4.4)")

N_FEATURES = X_train_n.shape[1]

def criar_modelo(dropout_rate=0.3, n_units_1=64, n_units_2=32):
    """
    Arquitetura: Dense → Dropout → Dense → Dropout → sigmoid
    Conectada ao bot:
      - input_shape=(7,) = 7 features do radar (versão flat, sem janela temporal)
      - sigmoid → P(UP) ∈ [0, 1]
      - binary_crossentropy = loss padrão para classificação binária (Chollet 4.1.3)
    No Bloco 1.C, a camada Dense será trocada por LSTM para capturar
    a janela temporal de 50 velas.
    """
    model = keras.Sequential([
        # Camada 1: aprende combinações de features (BBW × delta, squeeze patterns)
        layers.Dense(n_units_1, activation="relu",
                     input_shape=(N_FEATURES,),
                     name="dense_1"),
        # Dropout: zera 30% dos neurônios aleatoriamente em cada batch de treino.
        # Impede que o modelo "memorize" padrões específicos do treino.
        # (Chollet: "break up happenstance patterns that aren't significant")
        layers.Dropout(dropout_rate, name="dropout_1"),

        # Camada 2: refinamento das representações
        layers.Dense(n_units_2, activation="relu", name="dense_2"),
        layers.Dropout(dropout_rate, name="dropout_2"),

        # Saída: P(UP) — um neurônio com sigmoid
        # sigmoid(x) = 1/(1+e^-x) → sempre em [0,1] → interpretável como probabilidade
        layers.Dense(1, activation="sigmoid", name="saida"),
    ], name="classificador_up_down_bot")

    model.compile(
        # Adam = SGD com momentum adaptativo — "a usually good default" (Chollet 4.1.3)
        optimizer=keras.optimizers.Adam(learning_rate=1e-3),
        # binary_crossentropy: mede distância entre P(UP) previsto e rótulo real (0 ou 1)
        # Equivalente a -[y·log(p) + (1-y)·log(1-p)]
        loss="binary_crossentropy",
        metrics=[
            "accuracy",
            # AUC: mais robusto que accuracy quando as classes estão desequilibradas
            keras.metrics.AUC(name="auc"),
        ],
    )
    return model

model = criar_modelo()

print()
model.summary()

print(f"""
  Por que essa arquitetura para o bot:
    Dense(64)  → aprende: "squeeze alto + delta_buy alto = pressão compradora"
    Dropout(0.3) → não memoriza padrões de treino específicos (generaliza)
    Dense(32)  → refina a representação
    Dense(1, sigmoid) → P(UP) — probabilidade de a vela subir

  Próximo (Bloco 1.C): a entrada flat (7,) vira janela temporal (50, 7) → LSTM
""")


# ══════════════════════════════════════════════════════════════════════════════
# SEÇÃO 7 — K-FOLD TEMPORAL  (Chollet 5.2, 5.3)
# ══════════════════════════════════════════════════════════════════════════════
# Chollet 5.3: "K-fold validation: split your data into K partitions.
# For each partition i, train on the remaining K-1 partitions and evaluate."
#
# ⚠️  K-FOLD TEMPORAL (não aleatório!):
# Para séries temporais, cada fold deve ser uma fatia CRONOLÓGICA.
# Fold 1: treina em [0..20%], valida em [20%..40%]
# Fold 2: treina em [0..40%], valida em [40%..60%]
# ... (walk-forward — o Kaabar chama de "expanding window")
# Isso simula como o modelo será usado em produção: sempre prevê o futuro.

print(f"\n[7] K-FOLD TEMPORAL (Walk-Forward — sem shuffle)")

K_FOLDS = 5
fold_size = len(X_train_n) // K_FOLDS
scores_acc = []
scores_auc = []

for fold in range(K_FOLDS):
    # Split: treina em [0..fold*size], valida em [fold*size..(fold+1)*size]
    i_inicio = 0
    i_fim_tr = (fold + 1) * fold_size
    i_fim_vl = min(i_fim_tr + fold_size, len(X_train_n))

    if i_fim_tr >= len(X_train_n) or i_fim_vl <= i_fim_tr:
        break

    X_f_tr, y_f_tr = X_train_n[i_inicio:i_fim_tr], y_train[i_inicio:i_fim_tr]
    X_f_vl, y_f_vl = X_train_n[i_fim_tr:i_fim_vl], y_train[i_fim_tr:i_fim_vl]

    if len(X_f_tr) < 20 or len(X_f_vl) < 10:
        continue

    # Modelo limpo para cada fold
    m_fold = criar_modelo()
    m_fold.fit(
        X_f_tr, y_f_tr,
        epochs=30,
        batch_size=32,
        verbose=0,
    )
    res = m_fold.evaluate(X_f_vl, y_f_vl, verbose=0)
    # res = [loss, accuracy, auc]
    acc_f = res[1]
    auc_f = res[2]
    scores_acc.append(acc_f)
    scores_auc.append(auc_f)
    n_tr = len(X_f_tr)
    n_vl = len(X_f_vl)
    print(f"    Fold {fold+1}/{K_FOLDS}: "
          f"train={n_tr:>4}  val={n_vl:>4}  "
          f"acc={acc_f*100:.1f}%  auc={auc_f:.3f}")

print(f"\n    K-Fold Results:")
print(f"    Accuracy: {np.mean(scores_acc)*100:.1f}% ± {np.std(scores_acc)*100:.1f}%")
print(f"    AUC:      {np.mean(scores_auc):.3f} ± {np.std(scores_auc):.3f}")

# Interpretação (Chollet 5.2.1)
if np.std(scores_acc) > 0.08:
    print(f"    ⚠️  Alta variância entre folds (std={np.std(scores_acc)*100:.1f}%) → "
          f"poucos dados ou não-estacionariedade.")
elif np.mean(scores_acc) < max(baseline_sempre_up, acc_regras) + 0.02:
    print(f"    ⚠️  Modelo não supera baseline — revise features ou aumente dados.")
else:
    print(f"    ✅  Modelo estável e acima do baseline.")


# ══════════════════════════════════════════════════════════════════════════════
# SEÇÃO 8 — TREINO FINAL  (Chollet 4.1.4 com EarlyStopping)
# ══════════════════════════════════════════════════════════════════════════════
# Chollet 4.1.4: "it's standard practice to reserve a subset of the training
# data as validation data."
# Chollet 5.4.3: "EarlyStopping callback — interrupt training as soon as
# validation metrics have stopped improving."

print(f"\n[8] TREINO FINAL (com EarlyStopping e monitoramento de overfitting)")

model_final = criar_modelo()

callbacks = [
