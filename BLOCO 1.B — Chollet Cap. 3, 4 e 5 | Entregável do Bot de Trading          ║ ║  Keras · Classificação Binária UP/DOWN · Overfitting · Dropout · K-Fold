# Parâmetros de normalização (carregados do JSON em produção)
NORM_MEAN = np.array(norm_params["mean"], dtype=np.float32)
NORM_STD  = np.array(norm_params["std"],  dtype=np.float32)
FEAT_NOMES = norm_params["features"]

def decidir_com_dl(asset: str, radar_dict: dict,
                   threshold_up: float = 0.60,
                   threshold_down: float = 0.40) -> str:
    """
    Substitui decidir_estrategia() no coordinator_radar().

    Parâmetros:
      asset       : 'BTC' | 'ETH' | 'SOL'
      radar_dict  : o dict que decidir_radar() já retorna (bbw, bbw_perc, etc.)
      threshold_up  : P(UP) >= threshold_up  → SNIPER_UP
      threshold_down: P(UP) <= threshold_down → SNIPER_DOWN
      (zona entre threshold_down e threshold_up → SEM_SINAL)

    Retorna: "SNIPER_UP" | "SNIPER_DOWN" | "SEM_SINAL"

    Latência alvo: < 100ms (testado na seção 12)
    """
    try:
        # Monta vetor de features na mesma ordem usada no treino
        bbw        = float(radar_dict.get("bbw_atual",     0.0))
        bbw_perc   = float(radar_dict.get("bbw_percentil", 50.0))
        squeeze    = float(radar_dict.get("squeeze",       False))
        delta_buy  = float(radar_dict.get("delta_buy",     0.5))
        delta_sell = 1.0 - delta_buy
        delta_ratio= delta_buy / (delta_sell + 1e-8)
        bbw_norm   = bbw * bbw_perc / 100.0

        feat_vec = np.array([[bbw, bbw_perc, squeeze, delta_buy,
                              delta_sell, delta_ratio, bbw_norm]],
                            dtype=np.float32)

        # Normalização com parâmetros do TREINO (não recalcula)
        feat_norm = (feat_vec - NORM_MEAN) / NORM_STD

        # Inferência (o Keras não altera pesos em predict — thread-safe)
        prob_up = float(modelo_producao.predict(feat_norm, verbose=0)[0, 0])

        # Zona de incerteza → SEM_SINAL (o bot pula a vela)
        if prob_up >= threshold_up:
            return "SNIPER_UP"
        elif prob_up <= threshold_down:
            return "SNIPER_DOWN"
        else:
            return "SEM_SINAL"

    except Exception as e:
        # Fallback seguro: nunca trava o coordinator_radar()
        return "SEM_SINAL"


