def gerar_dados_sinteticos(n=2000, seed=42):
    """
    Gera radar_velas.csv sintético quando o CSV real não está disponível.
    Replica fielmente o formato e a lógica do bot:
      - squeeze (bbw_perc <= 20) + delta_buy >= 0.70 → UP
      - squeeze + delta_buy <= 0.30                  → DOWN
      - resto                                         → FLAT (excluído do treino)
    Os dados simulados têm ruído realista para não gerar modelo perfeito.
    """
    np.random.seed(seed)
    ativos    = np.random.choice(["BTC", "ETH", "SOL"], n)
    bbw       = np.random.uniform(0.010, 0.120, n).round(5)
    bbw_perc  = np.random.uniform(0.0, 100.0, n).round(1)
    squeeze   = (bbw_perc <= 20).astype(int)
    delta_buy = np.clip(np.random.beta(2, 2, n), 0.05, 0.95).round(3)
    delta_sell= (1 - delta_buy).round(3)

    # Direção real com ruído de mercado (não é determinística)
    prob_up = np.zeros(n)
    prob_up += squeeze * (delta_buy - 0.50) * 1.5   # sinal principal
    prob_up += np.random.normal(0, 0.25, n)          # ruído realista
    vela_dir = np.where(prob_up > 0.10, "UP",
               np.where(prob_up < -0.10, "DOWN", "FLAT"))

    preco_base = np.random.uniform(20_000, 70_000, n)
    var_pct    = np.random.normal(0, 0.8, n).round(4)
    close_     = (preco_base * (1 + var_pct / 100)).round(2)
    open_      = preco_base.round(2)
    high_      = (np.maximum(open_, close_) * (1 + abs(np.random.normal(0, 0.002, n)))).round(2)
    low_       = (np.minimum(open_, close_) * (1 - abs(np.random.normal(0, 0.002, n)))).round(2)

    decisao = np.where(
        (squeeze == 1) & (delta_buy >= 0.70), "SNIPER_UP",
        np.where((squeeze == 1) & (delta_buy <= 0.30), "SNIPER_DOWN", "MALHA")
    )

    ts_base = int(pd.Timestamp("2024-01-01").timestamp())
    vela_ts = [
        pd.Timestamp(ts_base + i * 900, unit='s').strftime("%Y-%m-%d %H:%M")
        for i in range(n)
    ]

    df = pd.DataFrame({
        "vela_ts":   vela_ts,
        "ativo":     ativos,
        "bbw":       bbw,
        "bbw_perc":  bbw_perc,
        "squeeze":   squeeze,
        "delta_buy": delta_buy,
        "delta_sell":delta_sell,
        "decisao":   decisao,
        "vela_dir":  vela_dir,
        "open":      open_,
        "high":      high_,
        "low":       low_,
        "close":     close_,
        "var_pct":   var_pct,
    })
    return df


